# -----------------------------------------------------------------------
# JusticeChoreBot — environment variables
# Copy this file to .env and fill in the values below.
# NEVER commit .env to source control.
# -----------------------------------------------------------------------

# Bot token from the Discord Developer Portal (Bot → Token)
DISCORD_TOKEN=your_bot_token_here

# Right-click your Discord server icon → Copy Server ID
DISCORD_GUILD_ID=your_guild_id_here

# Right-click the reminder channel → Copy Channel ID
DISCORD_REMINDER_CHANNEL_ID=your_channel_id_here

# Name of the Discord role that is allowed to run /rotatechores (default: Parents)
PARENT_ROLE_NAME=Parents
